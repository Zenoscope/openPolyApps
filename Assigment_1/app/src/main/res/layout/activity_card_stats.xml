<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gameStatsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackgroundColour">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screenBackgroundColour">


        <LinearLayout
            android:id="@+id/gameStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_centerInParent="true"
                android:layout_margin="20dp"
                android:fontFamily="@font/aldrich"
                android:gravity="center"
                android:text="Game Stats"
                android:textAlignment="center"
                android:textColor="@color/titleScreenGameName"
                android:textSize="20dp" />

            <LinearLayout
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"></LinearLayout>


        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="291dp"
        android:layout_weight="1"
        android:background="@drawable/rect_button_main"
        android:gravity="center"
        android:text="main menu"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="@id/gameStatsMain"
        app:layout_constraintEnd_toEndOf="@id/gameStatsMain"
        app:layout_constraintStart_toStartOf="@id/gameStatsMain" />

</androidx.constraintlayout.widget.ConstraintLayout>

