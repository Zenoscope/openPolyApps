<androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_margin="10dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        app:cardBackgroundColor="@color/cardListButton"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:id="@+id/showCard">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="15dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="550dp"
        tools:layout_editor_absoluteX="10dp"
        tools:layout_editor_absoluteY="10dp">

        <TextView
            android:id="@+id/playCost"
            android:layout_width="100dp"
            android:layout_height="60dp"
            android:layout_margin="10dp"
            android:textColor="@color/cardButtonText"
            android:text="Playcost 0"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@+id/characterimage"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            />

        <TextView
            android:id="@+id/battlePoints"
            android:layout_width="150dp"
            android:layout_height="60dp"
            android:layout_margin="10dp"
            android:text="000 BP"
            android:textSize="34sp"

            tools:layout_editor_absoluteX="272dp"
            tools:layout_editor_absoluteY="15dp"
            app:layout_constraintBottom_toTopOf="@+id/characterimage"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:gravity="right"
            android:textColor="@color/cardButtonText"
            />
        <!-- app:layout_constraintLeft_toRightOf="@+id/playCost"-->

        <ImageView
            android:id="@+id/characterimage"
            android:layout_width="match_parent"
            android:layout_height="309dp"
            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Mauris fringilla facilisis rhoncus."
            tools:layout_editor_absoluteX="16dp"
            tools:layout_editor_absoluteY="113dp"
            app:layout_constraintTop_toBottomOf="@+id/battlePoints"
            />

        <TextView
            android:id="@+id/effect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:lines="6"
            android:textSize="20sp"
            android:text="TextView"
            android:textColor="@color/cardButtonText"
            app:layout_constraintTop_toBottomOf="@id/characterimage"
            tools:layout_editor_absoluteX="177dp"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="550dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topLayout">

        <TextView
            android:id="@+id/cardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="#DBCECE"
            android:text="cardname"
            android:textAlignment="center"
            android:textSize="30sp"
            tools:layout_editor_absoluteX="10dp"
            />

        <TextView
            android:id="@+id/level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:text="level"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardName"
            app:layout_constraintBottom_toBottomOf="@id/cardName"
            android:layout_margin="10dp"
            />

        <TextView
            android:id="@+id/element"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="#FFFFFF"
            android:text="Earth"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/cardName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardName" />

        />
    </androidx.constraintlayout.widget.ConstraintLayout>
   </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>