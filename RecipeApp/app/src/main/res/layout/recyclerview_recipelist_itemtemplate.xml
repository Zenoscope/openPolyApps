<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    style="@style/BackgroundColour"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context="com.bit603.a2.UserRecyclerViewTemplate">

    <!-- make sure the
    android:layout_height="wrap_content"
    in the card view is "wrap_content" otherwise it fills the view,
    and covers the other items -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:cardBackgroundColor="@color/FillColour"
        app:contentPadding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/recipeName"
                style="@style/BackgroundColour"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button"
                android:text=""
                android:textAlignment="viewStart"
                android:textColor="@color/BtnTextColour"
                android:textSize="20dp"
                android:textStyle="bold" />

            <!-- hidden by default -->
            <ImageView
                android:id="@+id/heart"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:visibility="invisible"
                app:srcCompat="@drawable/heart_blue" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.cardview.widget.CardView>