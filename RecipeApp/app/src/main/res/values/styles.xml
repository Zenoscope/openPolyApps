<?xml version="1.0" encoding="utf-8"?>

<resources>

    <!-- recipe title -->
    <!--
    android:style="@style/RecipeNameText"
    -->
    <style name="RecipeNameText" parent="TextAppearance.AppCompat">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- recipe subtitle -->
    <!--
    android:style="@style/SubtitleText"
    -->
    <style name="SubtitleText" parent="TextAppearance.AppCompat">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- recipe Prep/Cook -->
    <!--
    android:style="@style/PrepCookText"
    -->
    <style name="PrepCookText" parent="TextAppearance.AppCompat">
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Background colour -->
    <!--
    android:style="@style/BackgroundColour"
    -->
    <style name="BackgroundColour" parent="TextAppearance.AppCompat">
        <item name="android:background">#250FB9</item>
    </style>

    <!-- Recipe image padding -->
    <!--
    android:style="@style/recipeImagePadding"
    -->
    <style name="recipeImagePadding" parent="TextAppearance.AppCompat">
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:layout_gravity">center</item>
    </style>

</resources>
